server {
  listen 443 ssl http2;
  server_name phapmontamlinh-quantheambotat.vn www.phapmontamlinh-quantheambotat.vn;

  ssl_certificate /etc/letsencrypt/live/phapmontamlinh-quantheambotat.vn/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/phapmontamlinh-quantheambotat.vn/privkey.pem;

  # Strong defaults
  ssl_session_cache shared:SSL:10m;
  ssl_session_timeout 10m;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers off;

  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

  resolver 127.0.0.11 valid=30s;

  location = /admin/ { return 301 /admin; }

  location ^~ /api/ {
    proxy_pass http://backend:1337;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
  }

  location ^~ /admin {
    proxy_pass http://backend:1337;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
  }

  location / {
    proxy_pass http://frontend:3000;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection 'upgrade';
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
  }
}
